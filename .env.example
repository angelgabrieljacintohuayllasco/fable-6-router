# Tu project id de Google Cloud (Vertex AI). Necesitas gcloud auth application-default login.
FABLE_ROUTER_GCP_PROJECT=tu-project-id
FABLE_ROUTER_GCP_LOCATION=global

# Opcional: Qwen real (qwen3.7-max) via Alibaba Cloud Model Studio.
# Si no la seteás, el router usa Qwen 3.6 Plus via OpenCode Go como fallback.
# Key gratis en https://bailian.console.aliyun.com/ (Model Studio).
# DASHSCOPE_API_KEY=tu-api-key

# Opcional: solo si tu key de Model Studio es workspace-scoped (la nueva
# pasarela MaaS regional) en vez del endpoint global clásico. Ver README.
# FABLE_ROUTER_DASHSCOPE_BASE_URL=https://{WorkspaceId}.ap-southeast-1.maas.aliyuncs.com/compatible-mode/v1
